<%- include('p/header'); -%>
<meta property="og:title" content="Happy Wedding Anniversary" />
<meta property="og:description" content="Kannur Area Women's Fellowship, Wish you a Happy Wedding Anniversary" />
<meta property="og:image" content="images/logo1.png" />
<link rel="icon" type="image/png" href="images/logo1.png">
<title>KNR Area Wedding Anniversary Wishes</title>
</head>
<body>
<%- include('p/navbar'); -%>
<div class="text-center">
  <div class="container">
    <h1 class="display-3">Happy Wedding Anniversary</h1>
  </div>
</div>

<div class="album py-5 bg-light text-center">
  <div class="container">
  <div class="row row-cols-1 row-cols-md-3"> 

            <% for(var i=0; i<bd[0].name.length; i++){ %>
            
              <div class="col col-sm-6 col-md-4 col-lg-3 mb-4">
                <div class="card h-100 text-white bg-dark text-center" >
                  <a href="wf-wedding/wf/<%=i%>"><img src="<%= bd[0].image[i] %>" class="card-img-top" alt="..."></a>
                  <div class="card-body">
                    <h5 class="card-title"><%= bd[0].name[i] %></h5>
                    <a href="whatsapp://send?text=https://wishes-aj.herokuapp.com/wf-wedding/wf/<%=i%>"
                    data-action="share/whatsapp/share"
                    target="_blank"><img src="images/share.png" alt="" width="70px"></a>
                    <!-- <a class="btn btn-outline-light my-2 my-sm-0 mr-3" href="/login" role="button">Login</a> -->
                  </div>
                </div>
              </div>
            
          <% } %>    

          <div class="col col-sm-6 col-md-4 col-lg-3 mb-4"  onclick="window.location.href='/wf-birthday'">
            <div class="card h-100 text-white bg-dark text-center" >
              <img src="images/birthday.jpg" class="card-img-top" alt="...">
              <div class="card-body card-birthday">
                <h5 class="card-title ">Today's Birthday</h5>
                <button type="button" class="btn btn-success" onclick="window.location.href='/wf-birthday'">View</button>
              </div>
            </div>
          </div>
            
    </div>
  </div>
</div>

<%- include('p/footer'); -%>