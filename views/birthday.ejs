<%- include('p/header'); -%>
<meta property="og:title" content="Happy Birthday Wishes" />
<meta property="og:description" content="Kannur Area Women's Fellowship, Wish you a Happy Birthday" />
<meta property="og:image" content="images/logo1.png" />
<link rel="icon" type="image/png" href="images/logo1.png">
<title>KNR Area Birthday Wishes</title>
</head>
<body>
<%- include('p/navbar'); -%>
<div class="text-center">
  <div class="container">
    <h1 class="display-3">Happy Birthday</h1>
  </div>
</div>
<div class="album py-5 bg-light text-center">
  <div class="container">

  <div class="row row-cols-1 row-cols-md-3"> 

            <% for(var i=0; i<bd[0].name.length; i++){ %>
            
              <div class="col col-sm-6 col-md-4 col-lg-3 mb-4">
                <div class="card h-100 text-white bg-dark text-center">
                  <div class="card-body">
                    <h2 class="card-title"><%= bd[0].name[i] %></h5>
                      <p class="card-text"><%= bd[0].place[i] %></p>
                    <a href="whatsapp://send?text=https://birthday-wf.herokuapp.com/wf-birthday/wf/<%=i%>"
                    data-action="share/whatsapp/share"
                    target="_blank"><img src="images/share.png" alt="" width="70px"></a>
                  </div>
                </div>
              </div>
            
          <% } %>     

          <div class="col col-sm-6 col-md-4 col-lg-3 mb-4"  onclick="window.location.href='/wf-wedding'">
            <div class="card h-100 text-white bg-dark text-center" >
              <div class="card-body">
                <h5 class="card-title">View Today's Wedding Anniversary</h5>
                <button type="button" class="btn btn-success button-birthday" onclick="window.location.href='/wf-birthday'">View</button>
              </div>
            </div>
          </div>
            
    </div>
  </div>
</div>

<%- include('p/footer'); -%>